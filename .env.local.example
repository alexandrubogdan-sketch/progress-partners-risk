# Copy to .env.local for local dev. NEVER commit real values.

# JSON map of account name -> Stripe restricted key (rk_live_...)
# Keys need read access to: Charges, Disputes, Radar Early Fraud Warnings.
STRIPE_ACCOUNTS={"Account-Name":"rk_live_xxx","Other-Account":"rk_live_yyy"}

# Vercel Blob read-write token (auto-injected on Vercel once a Blob store
# is connected to the project; only needed for local dev)
BLOB_READ_WRITE_TOKEN=

# Shared secret protecting /api/cron/refresh (set the same value in Vercel)
CRON_SECRET=change-me
