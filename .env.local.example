# Copy to .env.local for local dev. NEVER commit real values.

# JSON map of account name -> Stripe restricted key (rk_live_...)
# Keys need read access to: Charges, Disputes, Radar Early Fraud Warnings.
STRIPE_ACCOUNTS={"Account-Name":"rk_live_xxx","Other-Account":"rk_live_yyy"}

# Solidgate channels (one per Hub channel/descriptor). Use either shape:
#   Map shape (recommended):
#     {"Product/Channel": {"publicKey":"api_pk_...","secretKey":"api_sk_...","descriptor":"DESC"}, ...}
#   Array shape:
#     [{"name":"PDF-prod/files-editor","product":"PDF-prod","descriptor":"FILES-EDITOR","publicKey":"api_pk_...","secretKey":"api_sk_..."}, ...]
# product + descriptor are optional — they default to splitting the name on "/".
SOLIDGATE_ACCOUNTS=

# Vercel Blob read-write token (auto-injected on Vercel once a Blob store
# is connected to the project; only needed for local dev)
BLOB_READ_WRITE_TOKEN=

# Public URL to the latest snapshot blob (the /api/vamp route reads from here)
# After first cron run, copy the URL Vercel Blob writes to into this env var.
BLOB_SNAPSHOT_URL=

# Shared secret protecting /api/cron/refresh (set the same value in Vercel)
CRON_SECRET=change-me
