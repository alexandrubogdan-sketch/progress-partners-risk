# n8n webhook URL that returns the VAMP data as JSON
# Set up a Webhook trigger node in n8n that responds to GET requests
# and returns the same 158-row VAMP payload your workflow computes.
N8N_WEBHOOK_URL=https://progresspartners.app.n8n.cloud/webhook/YOUR_WEBHOOK_ID
